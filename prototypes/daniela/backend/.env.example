# Google AI Studio: https://aistudio.google.com/apikey
# google-genai picks this up automatically for genai.Client() (or use GOOGLE_API_KEY).
GEMINI_API_KEY=yelllllo
# Optional: model id (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-2.5-flash
# Optional: max output tokens per reply (default 1024; raise only if replies still truncate mid-thought)
# GEMINI_CHAT_MAX_OUTPUT_TOKENS=1536

# Test GitHub + graph UI without Gemini (folder-structure graph; chat returns a stub).
# GITMAP_SKIP_GEMINI=1

# GitHub token: https://github.com/settings/tokens — raises GraphQL rate limits (recommended)
GITHUB_TOKEN=
